-- FPS Boost (Lag Reduction) Toggle
local cleanupLoop

local function RemoveLag()
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or
           v:IsA("Fire") or v:IsA("Sparkles") or v:IsA("Explosion") then
            pcall(function() v:Destroy() end)
        elseif v:IsA("Decal") or v:IsA("Texture") then
            pcall(function() v:Destroy() end)
        end
    end
end

Tabs.Main:AddToggle("FPSBoost", {
    Title = "FPS Boost",
    Description = "Removes lag-causing effects every 30 seconds",
    Default = false,
    Callback = function(enabled)
        if enabled then
            RemoveLag()  -- clean once immediately
            cleanupLoop = task.spawn(function()
                while task.wait(30) do
                    if not getgenv().FPSBoostEnabled then break end
                    RemoveLag()
                end
            end)
        else
            if cleanupLoop then
                task.cancel(cleanupLoop)
                cleanupLoop = nil
            end
        end
        
        getgenv().FPSBoostEnabled = enabled  -- better than using Value directly in loop
    end
})

