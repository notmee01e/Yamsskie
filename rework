local function farmRocks(neededDurabilityValue)
    task.spawn(function()
        while getgenv().autoFarm do
            task.wait(0.1)
            local character = player.Character
            if character and player.Durability.Value >= neededDurabilityValue then
                for _, v in pairs(workspace.machinesFolder:GetDescendants()) do
                    if v.Name == "neededDurability" and v.Value == neededDurabilityValue then
                        local leftHand = character:FindFirstChild("LeftHand")
                        local rightHand = character:FindFirstChild("RightHand")
                        
                        if leftHand and rightHand then
                            local rock = v.Parent:FindFirstChild("Rock")
                            if rock then
                                firetouchinterest(rock, rightHand, 0)
                                firetouchinterest(rock, rightHand, 1)
                                firetouchinterest(rock, leftHand, 0)
                                firetouchinterest(rock, leftHand, 1)
                                gettool()
                            end
                        end
                    end
                end
            end
            
            -- Fast punches if active
            if getgenv().fastHitActive then
                player.muscleEvent:FireServer("punch", "rightHand")
                player.muscleEvent:FireServer("punch", "leftHand")
                
                if character then
                    local punchTool = character:FindFirstChild("Punch")
                    if punchTool then punchTool:Activate() end
                end
            end
        end
    end)
end

Tabs.AutoFarm:AddToggle("FastTools", {
    Title = "Fast Tools",
    Description = "Removes cooldown on all lift tools (Punch, Slam, Stomp, etc.)",
    Default = false,
    Callback = function(enabled)
        getgenv().FastTools = enabled
        
        local toolsData = {
            { "Punch",        "attackTime", enabled and 0 or 0.1 },
            { "Ground Slam",  "attackTime", enabled and 0 or 6   },
            { "Stomp",        "attackTime", enabled and 0 or 7   },
            { "Handstands",   "repTime",    enabled and 0 or 1   },
            { "Pushups",      "repTime",    enabled and 0 or 1   },
            { "Weight",       "repTime",    enabled and 0 or 1   },
            { "Situps",       "repTime",    enabled and 0 or 1   }
        }
        
        local player = game.Players.LocalPlayer
        local backpack = player:WaitForChild("Backpack")
        local character = player.Character
        
        for _, data in ipairs(toolsData) do
            local toolName, propName, newValue = data[1], data[2], data[3]
            
            -- Check backpack
            local tool = backpack:FindFirstChild(toolName)
            if tool and tool:FindFirstChild(propName) then
                tool[propName].Value = newValue
            end
            
            -- Check equipped tool
            if character then
                local equipped = character:FindFirstChild(toolName)
                if equipped and equipped:FindFirstChild(propName) then
                    equipped[propName].Value = newValue
                end
            end
        end
        
        -- Optional: notify once when toggled
        Fluent:Notify({
            Title = "Fast Tools",
            Content = enabled and "All tools set to zero cooldown!" or "Tools restored to normal",
            Duration = 3
        })
    end
})

