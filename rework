-- Function to safely get an object with timeout
local function safeWaitForChild(parent, childName, timeout)
    timeout = timeout or 2 -- Default timeout of 5 seconds
    local startTime = tick()
    local object = parent:FindFirstChild(childName)
    
    while not object and tick() - startTime < timeout do
        object = parent:FindFirstChild(childName)
        if object then break end
        task.wait(0)
    end
    
    if not object then
        warn("Failed to find", childName, "in", parent, "after", timeout, "seconds")
    end
    return object
end

